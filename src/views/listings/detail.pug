extends ../layout

block content
  - const formatDate = (value) => { if (!value) return 'Not set'; const date = new Date(value); return Number.isNaN(date.getTime()) ? 'Not set' : date.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }); }
  - const formatDateTime = (value) => { if (!value) return 'Not set'; const date = new Date(value); return Number.isNaN(date.getTime()) ? 'Not set' : date.toLocaleString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }); }
  - const statusLabel = (value) => value ? String(value).replace('_', ' ') : 'UNKNOWN'
  - const cleanStatus = String(listing.status || 'UNKNOWN').toLowerCase().replace('_', '-')
  - const reportSuccess = typeof query !== 'undefined' && query.report_success
  - const reportError = typeof query !== 'undefined' && query.report_error

  .listing-detail-page
    .listing-detail-topbar
      a(href='/listings') ← Back to Listings
      if claimState && claimState.isOwner
        a(href='/my-listings') My Listings

    .listing-detail-hero
      .listing-detail-media
        if listing.image_path
          img(src=listing.image_path, alt=listing.title)
        else
          .listing-detail-placeholder
            span= listing.category_name ? listing.category_name.charAt(0).toUpperCase() : 'F'

      .listing-detail-summary
        span(class=`detail-status detail-status--${cleanStatus}`)= statusLabel(listing.status)
        h1= listing.title
        p= listing.description

        .detail-owner-box
          .detail-owner-avatar= listing.owner_username ? listing.owner_username.charAt(0).toUpperCase() : 'U'
          div
            span Shared by
            strong= listing.owner_username

        if claimState && !claimState.isOwner
          button.detail-report-button#openReportModal(type='button') Report listing issue

        .detail-action-card
          if reportSuccess
            .detail-feedback.detail-feedback--success
              strong Report Submitted
              p Thank you. Your report has been sent to the listing owner.

          if reportError
            .detail-feedback.detail-feedback--error
              strong Report Error
              if reportError === 'own_listing'
                p You cannot report your own listing.
              else if reportError === 'reason_required'
                p Please choose a reason before submitting a report.
              else
                p Report could not be submitted. Please try again.

          if claimFeedback
            .detail-feedback(class=claimFeedback.type === 'success' ? 'detail-feedback--success' : 'detail-feedback--error')
              strong= claimFeedback.type === 'success' ? 'Claim Update' : 'Claim Error'
              p= claimFeedback.message

          if claimState && claimState.canClaim
            h2 Claim this food
            p Send a claim request to the listing owner. They can confirm or reject the request.
            form(method='POST', action=`/listings/${listing.listing_id}/claim`)
              button.detail-primary-button(type='submit') Submit Claim Request
          else if claimState && claimState.isOwner && claimState.activeClaim
            h2 Manage claim request
            p A community member has requested this listing.
            .detail-claim-info
              span Claimant: #{claimState.activeClaim.claimant_username}
              span Status: #{claimState.activeClaim.status}
              span Claimed: #{formatDateTime(claimState.activeClaim.called_at)}

            .detail-owner-actions
              if claimState.canConfirm
                form(method='POST', action=`/listings/${listing.listing_id}/claim/${claimState.activeClaim.claims_id}/status`)
                  input(type='hidden', name='action', value='confirm')
                  button.detail-primary-button(type='submit') Confirm Claim

              if claimState.canReject
                form(method='POST', action=`/listings/${listing.listing_id}/claim/${claimState.activeClaim.claims_id}/status`)
                  input(type='hidden', name='action', value='reject')
                  button.detail-danger-button(type='submit') Reject Claim

              if claimState.canComplete
                form(method='POST', action=`/listings/${listing.listing_id}/claim/${claimState.activeClaim.claims_id}/status`)
                  input(type='hidden', name='action', value='complete')
                  button.detail-primary-button(type='submit') Complete Claim
          else if claimState && claimState.isOwner
            h2 Your listing
            p No live claim exists for this listing yet.
            a.detail-secondary-button(href='/my-listings') Manage My Listings
          else if claimState && claimState.activeClaim
            h2 Claim status
            p This listing already has an active claim.
            .detail-claim-info
              span Status: #{claimState.activeClaim.status}
              span Claimed: #{formatDateTime(claimState.activeClaim.called_at)}
          else
            h2 Not available
            p This listing is not currently available for claiming.

    .listing-detail-info-grid
      .detail-info-card
        span Category
        strong= listing.category_name

      .detail-info-card
        span Quantity
        strong= listing.quantity

      .detail-info-card
        span Expiry Date
        strong= formatDate(listing.expiry_date)

      .detail-info-card
        span Pickup Location
        strong= listing.pickup_location

      .detail-info-card
        span Collection Start
        strong= formatDateTime(listing.collection_start)

      .detail-info-card
        span Collection End
        strong= formatDateTime(listing.collection_end)

    if listing.tags
      .listing-detail-tags
        h2 Tags
        p= listing.tags

  if claimState && !claimState.isOwner
    .report-modal#reportListingModal(aria-hidden='true')
      .report-modal__backdrop
      .report-modal__box
        h2 Report listing issue
        p Tell the owner what problem you noticed with this listing.

        form(method='POST', action=`/listings/${listing.listing_id}/report`)
          .report-field
            label(for='report_reason') Reason
            select#report_reason(name='report_reason', required)
              option(value='') Select a reason
              option(value='Incorrect listing information') Incorrect listing information
              option(value='Food appears unsafe or expired') Food appears unsafe or expired
              option(value='Pickup details are unclear') Pickup details are unclear
              option(value='Duplicate or misleading listing') Duplicate or misleading listing
              option(value='Other issue') Other issue

          .report-field
            label(for='report_details') Extra details
            textarea#report_details(name='report_details', maxlength='180', placeholder='Briefly explain the issue')

          .report-modal__actions
            button.report-modal__cancel#cancelReportListing(type='button') Cancel
            button.report-modal__submit(type='submit') Submit Report

  script.
    const reportModal = document.getElementById('reportListingModal');
    const openReportButton = document.getElementById('openReportModal');
    const cancelReportButton = document.getElementById('cancelReportListing');

    if (openReportButton && reportModal) {
      openReportButton.addEventListener('click', function () {
        reportModal.classList.add('report-modal--open');
        reportModal.setAttribute('aria-hidden', 'false');
      });
    }

    if (cancelReportButton && reportModal) {
      cancelReportButton.addEventListener('click', function () {
        reportModal.classList.remove('report-modal--open');
        reportModal.setAttribute('aria-hidden', 'true');
      });
    }

    if (reportModal) {
      reportModal.addEventListener('click', function (event) {
        if (event.target.classList.contains('report-modal__backdrop')) {
          reportModal.classList.remove('report-modal--open');
          reportModal.setAttribute('aria-hidden', 'true');
        }
      });
    }
