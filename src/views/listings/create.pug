extends ../layout

block content
  - const form = formData || {}

  .create-listing-page
    aside.create-listing-sidebar
      a.create-back-link(href='/my-listings') ← My Listings

      .create-sidebar-card
        h1 Want to share surplus food?
        p Fill out the details of your available food so we can create a listing to help reduce food waste.
        a.create-sidebar-button(href='/my-listings') My Listings

    section.create-listing-main
      .create-listing-header
        h1 Create Listing
        p Add clear food details so other community members know what is available.

      if errors && errors.length
        .create-alert
          h3 Please fix the following:
          ul
            each error in errors
              li= error

      form.create-listing-form(method='POST', action='/listings/create', enctype='multipart/form-data')
        .create-field
          label(for='title') Listing Title
          input#title(
            type='text',
            name='title',
            required,
            value=form.title ? form.title : '',
            placeholder='e.g. Fresh Sourdough Bread'
          )

        .create-field
          label(for='listing_image') Upload Image
          input#createListingImage.create-file-input(
            type='file',
            name='listing_image',
            accept='image/jpeg,image/png,image/webp'
          )
          label.create-upload-box(for='createListingImage')
            img#createImagePreview.create-upload-preview(src='', alt='Selected food image preview')
            .create-upload-icon#createUploadIcon 🖼
            p#createUploadText Click here to browse and upload a food image
            span#createUploadHelp JPG, PNG or WEBP only. Maximum file size: 5MB.
            .create-upload-button Browse Files

        .create-form-row
          .create-field
            label(for='category_id') Category
            select#category_id(name='category_id', required)
              option(value='') Select Category
              each category in categories
                option(
                  value=category.category_id,
                  selected=form.category_id == String(category.category_id) ? true : false
                )= category.name

          .create-field
            label(for='quantity') Serving Size
            input#quantity(
              type='number',
              name='quantity',
              min='1',
              required,
              value=form.quantity ? form.quantity : '',
              placeholder='e.g. 4 portions'
            )

        .create-form-row
          .create-field
            label(for='collection_start') Pickup Start
            input#collection_start(
              type='datetime-local',
              name='collection_start',
              required,
              value=form.collection_start ? form.collection_start : ''
            )

          .create-field
            label(for='collection_end') Pickup End
            input#collection_end(
              type='datetime-local',
              name='collection_end',
              required,
              value=form.collection_end ? form.collection_end : ''
            )

        .create-field.pickup-method-field
          label Pickup Location
          input#pickup_location(type='hidden', name='pickup_location', value=form.pickup_location ? form.pickup_location : '')

          .pickup-method-options
            label.pickup-method-option(for='pickupMethodApproved')
              input#pickupMethodApproved(type='radio', name='pickup_method', value='approved')
              span Use approved pickup point

            label.pickup-method-option(for='pickupMethodManual')
              input#pickupMethodManual(type='radio', name='pickup_method', value='manual')
              span Enter my own address

          .approved-pickup-panel#approvedPickupPanel
            label(for='approvedPickupSelect') Approved pickup point
            select#approvedPickupSelect
              option(value='') Select approved pickup point
              option(value='University of Roehampton Main Campus, Grove House, Roehampton Lane, London, SW15 5PJ', selected=form.pickup_location === 'University of Roehampton Main Campus, Grove House, Roehampton Lane, London, SW15 5PJ' ? true : false) University of Roehampton Main Campus — Grove House, Roehampton Lane, London, SW15 5PJ
              option(value='Putney Library, 5/7 Disraeli Road, London, SW15 2DR', selected=form.pickup_location === 'Putney Library, 5/7 Disraeli Road, London, SW15 2DR' ? true : false) Putney Library — 5/7 Disraeli Road, London, SW15 2DR
              option(value='Barnes Station, Station Road, Barnes, Greater London, SW13 0HT', selected=form.pickup_location === 'Barnes Station, Station Road, Barnes, Greater London, SW13 0HT' ? true : false) Barnes Station — Station Road, Barnes, Greater London, SW13 0HT
              option(value='Southfields Library, 300 Wimbledon Park Road, London, SW19 6NL', selected=form.pickup_location === 'Southfields Library, 300 Wimbledon Park Road, London, SW19 6NL' ? true : false) Southfields Library — 300 Wimbledon Park Road, London, SW19 6NL
              option(value='Wandsworth Town Hall, Wandsworth High Street, London, SW18 2PU', selected=form.pickup_location === 'Wandsworth Town Hall, Wandsworth High Street, London, SW18 2PU' ? true : false) Wandsworth Town Hall — Wandsworth High Street, London, SW18 2PU

          .manual-pickup-panel#manualPickupPanel
            label(for='manualPickupAddress') Manual pickup address
            input#manualPickupAddress(
              type='text',
              value=form.pickup_location ? form.pickup_location : '',
              placeholder='Enter full address and postcode'
            )

          p.pickup-help Approved pickup points are recommended. Manual addresses should include a full postcode.

        .create-field
          label(for='description') Additional Details
          textarea#description(
            name='description',
            required,
            maxlength='255',
            placeholder='Provide any additional information about the food e.g. ingredients, storage instructions, allergens'
          )= form.description ? form.description : ''

        .create-field
          label(for='expiry_date') Expiration Date
          input#expiry_date(
            type='date',
            name='expiry_date',
            required,
            value=form.expiry_date ? form.expiry_date : ''
          )

        .create-submit-row
          a.create-cancel-link(href='/my-listings') Cancel
          button.create-submit-button(type='submit') Create Listing

  script.
    const imageInput = document.getElementById('createListingImage');
    const imagePreview = document.getElementById('createImagePreview');
    const uploadIcon = document.getElementById('createUploadIcon');
    const uploadText = document.getElementById('createUploadText');
    const uploadHelp = document.getElementById('createUploadHelp');

    if (imageInput) {
      imageInput.addEventListener('change', function () {
        const file = this.files && this.files[0];

        if (!file) {
          return;
        }

        imagePreview.src = URL.createObjectURL(file);
        imagePreview.style.display = 'block';
        uploadIcon.style.display = 'none';
        uploadText.textContent = file.name;
        uploadHelp.textContent = 'Image selected. Click again to change it.';
      });
    }

  script.
    const approvedPickupValues = [
      'University of Roehampton Main Campus, Grove House, Roehampton Lane, London, SW15 5PJ',
      'Putney Library, 5/7 Disraeli Road, London, SW15 2DR',
      'Barnes Station, Station Road, Barnes, Greater London, SW13 0HT',
      'Southfields Library, 300 Wimbledon Park Road, London, SW19 6NL',
      'Wandsworth Town Hall, Wandsworth High Street, London, SW18 2PU'
    ];

    const pickupHiddenInput = document.getElementById('pickup_location');
    const approvedRadio = document.getElementById('pickupMethodApproved');
    const manualRadio = document.getElementById('pickupMethodManual');
    const approvedPanel = document.getElementById('approvedPickupPanel');
    const manualPanel = document.getElementById('manualPickupPanel');
    const approvedSelect = document.getElementById('approvedPickupSelect');
    const manualInput = document.getElementById('manualPickupAddress');
    const listingForm = document.querySelector('.create-listing-form');

    function setPickupMode(mode) {
      if (!approvedPanel || !manualPanel) {
        return;
      }

      if (mode === 'approved') {
        approvedPanel.style.display = 'block';
        manualPanel.style.display = 'none';
      } else {
        approvedPanel.style.display = 'none';
        manualPanel.style.display = 'block';
      }
    }

    function updatePickupHiddenValue() {
      if (!pickupHiddenInput) {
        return;
      }

      if (approvedRadio && approvedRadio.checked) {
        pickupHiddenInput.value = approvedSelect ? approvedSelect.value.trim() : '';
      } else {
        pickupHiddenInput.value = manualInput ? manualInput.value.trim() : '';
      }
    }

    if (pickupHiddenInput && approvedRadio && manualRadio) {
      const existingValue = pickupHiddenInput.value.trim();

      if (approvedPickupValues.includes(existingValue)) {
        approvedRadio.checked = true;
        if (approvedSelect) {
          approvedSelect.value = existingValue;
        }
        setPickupMode('approved');
      } else {
        manualRadio.checked = true;
        if (manualInput) {
          manualInput.value = existingValue;
        }
        setPickupMode('manual');
      }

      approvedRadio.addEventListener('change', function () {
        setPickupMode('approved');
        updatePickupHiddenValue();
      });

      manualRadio.addEventListener('change', function () {
        setPickupMode('manual');
        updatePickupHiddenValue();
      });

      if (approvedSelect) {
        approvedSelect.addEventListener('change', updatePickupHiddenValue);
      }

      if (manualInput) {
        manualInput.addEventListener('input', updatePickupHiddenValue);
      }

      if (listingForm) {
        listingForm.addEventListener('submit', function (event) {
          updatePickupHiddenValue();

          if (!pickupHiddenInput.value.trim()) {
            event.preventDefault();
            alert('Please select an approved pickup point or enter a manual pickup address.');
          }
        });
      }
    }
