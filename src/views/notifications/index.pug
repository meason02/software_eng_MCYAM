extends ../layout

block content
  - const formatDateTime = function(value) { if (!value) return 'Not set'; const date = new Date(value); return Number.isNaN(date.getTime()) ? 'Not set' : date.toLocaleString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }); }

  .activity-notifications-page
    aside.activity-notifications-sidebar
      .activity-notifications-sidebar__icon 🔔
      h1 Notifications
      .activity-notifications-sidebar__line
      p Stay updated on your listings, claims, collection requests and pickup activity.

    section.activity-notifications-main
      .activity-notifications-header
        div
          h1 Notifications
          p
            span#unreadCount= unreadCount || 0
            |  unread updates

        button#markAllRead.activity-mark-read(type='button') ✓ Mark all as read

      if notifications && notifications.length
        .activity-notification-list
          each item in notifications
            - const toneClass = item.tone ? `activity-notification--${item.tone}` : 'activity-notification--info'
            article(class=`activity-notification ${toneClass} ${item.isUnread ? 'activity-notification--unread' : ''}`)
              .activity-notification-icon
                span= item.icon || 'i'

              .activity-notification-body
                h3
                  strong= item.title
                  | : #{item.message}

                if item.subMessage
                  p= item.subMessage

              .activity-notification-time
                span= formatDateTime(item.time)

              .activity-notification-dot

              .activity-notification-actions
                if item.actionType === 'owner_decision'
                  form(method='POST', action=`/listings/${item.listing_id}/claim/${item.claims_id}/status`)
                    input(type='hidden', name='action', value='confirm')
                    button.activity-action-button.activity-action-button--accept(type='submit') Accept

                  form(method='POST', action=`/listings/${item.listing_id}/claim/${item.claims_id}/status`)
                    input(type='hidden', name='action', value='reject')
                    button.activity-action-button.activity-action-button--decline(type='submit') Decline

                  a.activity-action-link(href=`/listings/${item.listing_id}`) View Details
                else if item.type === 'report_submitted'
                  button.activity-action-link.report-view-trigger(
                    type='button',
                    data-report-message=item.message,
                    data-report-reason=item.subMessage || 'No extra reason provided.'
                  ) View Report
                  a.activity-action-link(href=item.actionUrl || '/listings') View Listing
                else
                  a.activity-action-link(href=item.actionUrl || '/listings')= item.actionLabel || 'View'
      else
        .activity-notifications-empty
          h2 No notifications yet
          p Important updates about your listings and claims will appear here.

  .report-view-modal#reportViewModal(aria-hidden='true')
    .report-view-modal__backdrop
    .report-view-modal__box
      h2 Report Details
      p#reportViewMessage Report information will appear here.
      .report-view-reason
        strong Reason given:
        p#reportViewReason No reason provided.
      .report-view-modal__actions
        button.report-view-modal__close#closeReportView(type='button') Close

  script.
    const markAllReadButton = document.getElementById('markAllRead');
    const unreadCount = document.getElementById('unreadCount');

    if (markAllReadButton) {
      markAllReadButton.addEventListener('click', function () {
        document.querySelectorAll('.activity-notification--unread').forEach(function (item) {
          item.classList.remove('activity-notification--unread');
        });

        if (unreadCount) {
          unreadCount.textContent = '0';
        }
      });
    }

  script.
    const reportViewModal = document.getElementById('reportViewModal');
    const reportViewMessage = document.getElementById('reportViewMessage');
    const reportViewReason = document.getElementById('reportViewReason');
    const closeReportView = document.getElementById('closeReportView');

    document.querySelectorAll('.report-view-trigger').forEach(function (button) {
      button.addEventListener('click', function () {
        reportViewMessage.textContent = button.getAttribute('data-report-message') || 'A report was submitted.';
        reportViewReason.textContent = button.getAttribute('data-report-reason') || 'No reason provided.';
        reportViewModal.classList.add('report-view-modal--open');
        reportViewModal.setAttribute('aria-hidden', 'false');
      });
    });

    if (closeReportView) {
      closeReportView.addEventListener('click', function () {
        reportViewModal.classList.remove('report-view-modal--open');
        reportViewModal.setAttribute('aria-hidden', 'true');
      });
    }

    if (reportViewModal) {
      reportViewModal.addEventListener('click', function (event) {
        if (event.target.classList.contains('report-view-modal__backdrop')) {
          reportViewModal.classList.remove('report-view-modal--open');
          reportViewModal.setAttribute('aria-hidden', 'true');
        }
      });
    }
